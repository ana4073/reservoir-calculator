<Window x:Class=\"ReservoirCalculator.MainWindow\"\n        xmlns=\"http://schemas.microsoft.com/winfx/2006/xaml/presentation\"\n        xmlns:x=\"http://schemas.microsoft.com/winfx/2006/xaml\"\n        xmlns:h=\"http://helix-toolkit.org/wpf\"\n        xmlns:local=\"clr-namespace:ReservoirCalculator.Converters\"\n        Title=\"Калькулятор РВС/РГС - Расчет кубатуры резервуаров\" \n        Height=\"900\" \n        Width=\"1400\"\n        WindowStartupLocation=\"CenterScreen\"\n        Background=\"#F5F5F5\">\n    <Window.Resources>\n        <local:ReservoirTypeConverter x:Key=\"ReservoirTypeConverter\"/>\n    </Window.Resources>\n    <DockPanel>\n        <StackPanel DockPanel.Dock=\"Top\" Background=\"#2C3E50\" Padding=\"20\" Orientation=\"Horizontal\">\n            <TextBlock Text=\"Калькулятор резервуаров РВС/РГС\" \n                       FontSize=\"24\" \n                       FontWeight=\"Bold\" \n                       Foreground=\"White\" \n                       VerticalAlignment=\"Center\"/>\n        </StackPanel>\n\n        <Grid>\n            <Grid.ColumnDefinitions>\n                <ColumnDefinition Width=\"350\"/>\n                <ColumnDefinition Width=\"*\"/>\n            </Grid.ColumnDefinitions>\n\n            <ScrollViewer Grid.Column=\"0\" Background=\"White\" Padding=\"20\">\n                <StackPanel Margin=\"0,0,0,15\">\n                    <GroupBox Header=\"Тип резервуара\" Padding=\"15\" Margin=\"0,0,0,15\">\n                        <StackPanel>\n                            <ComboBox ItemsSource=\"{Binding ReservoirTypes}\" \n                                      SelectedItem=\"{Binding SelectedReservoirType}\"\n                                      Padding=\"8\"/>\n                        </StackPanel>\n                    </GroupBox>\n\n                    <GroupBox Header=\"Основные параметры\" Padding=\"15\" Margin=\"0,0,0,15\">\n                        <StackPanel>\n                            <StackPanel Margin=\"0,0,0,12\">\n                                <TextBlock Text=\"Диаметр (м):\" FontWeight=\"Bold\" Margin=\"0,0,0,5\"/>\n                                <TextBox Text=\"{Binding Diameter, StringFormat=F2}\" \n                                         Padding=\"8\" \n                                         FontSize=\"12\" Margin=\"0,0,0,5\"/>\n                                <Slider Value=\"{Binding Diameter}\" \n                                        Minimum=\"1\" \n                                        Maximum=\"20\" \n                                        Margin=\"0,5,0,0\"/>\n                            </StackPanel>\n\n                            <StackPanel Margin=\"0,0,0,12\">\n                                <TextBlock Text=\"Высота/Длина (м):\" FontWeight=\"Bold\" Margin=\"0,0,0,5\"/>\n                                <TextBox Text=\"{Binding Height, StringFormat=F2}\" \n                                         Padding=\"8\" \n                                         FontSize=\"12\" Margin=\"0,0,0,5\"/>\n                                <Slider Value=\"{Binding Height}\" \n                                        Minimum=\"1\" \n                                        Maximum=\"25\" \n                                        Margin=\"0,5,0,0\"/>\n                            </StackPanel>\n\n                            <StackPanel Margin=\"0,0,0,12\">\n                                <TextBlock Text=\"Толщина стенок (мм):\" FontWeight=\"Bold\" Margin=\"0,0,0,5\"/>\n                                <TextBox Text=\"{Binding WallThickness, StringFormat=F1}\" \n                                         Padding=\"8\" \n                                         FontSize=\"12\" Margin=\"0,0,0,5\"/>\n                                <Slider Value=\"{Binding WallThickness}\" \n                                        Minimum=\"5\" \n                                        Maximum=\"50\" \n                                        Margin=\"0,5,0,0\"/>\n                            </StackPanel>\n                        </StackPanel>\n                    </GroupBox>\n\n                    <GroupBox Header=\"Параметры РВС\" Padding=\"15\" Margin=\"0,0,0,15\"\n                              Visibility=\"{Binding SelectedReservoirType, Converter={StaticResource ReservoirTypeConverter}, ConverterParameter=РВС}\">\n                        <StackPanel>\n                            <StackPanel Margin=\"0,0,0,12\">\n                                <TextBlock Text=\"Тип крыши:\" FontWeight=\"Bold\" Margin=\"0,0,0,5\"/>\n                                <ComboBox ItemsSource=\"{Binding RoofTypes}\" \n                                          SelectedItem=\"{Binding SelectedRoofType}\"\n                                          Padding=\"8\"/>\n                            </StackPanel>\n\n                            <StackPanel Margin=\"0,0,0,12\">\n                                <TextBlock Text=\"Высота крыши (м):\" FontWeight=\"Bold\" Margin=\"0,0,0,5\"/>\n                                <TextBox Text=\"{Binding RoofHeight, StringFormat=F2}\" \n                                         Padding=\"8\" \n                                         FontSize=\"12\" Margin=\"0,0,0,5\"/>\n                                <Slider Value=\"{Binding RoofHeight}\" \n                                        Minimum=\"0.2\" \n                                        Maximum=\"3\" \n                                        Margin=\"0,5,0,0\"/>\n                            </StackPanel>\n                        </StackPanel>\n                    </GroupBox>\n\n                    <GroupBox Header=\"Параметры РГС\" Padding=\"15\" Margin=\"0,0,0,15\"\n                              Visibility=\"{Binding SelectedReservoirType, Converter={StaticResource ReservoirTypeConverter}, ConverterParameter=РГС}\">\n                        <StackPanel>\n                            <StackPanel Margin=\"0,0,0,12\">\n                                <TextBlock Text=\"Тип днища:\" FontWeight=\"Bold\" Margin=\"0,0,0,5\"/>\n                                <ComboBox ItemsSource=\"{Binding BottomTypes}\" \n                                          SelectedItem=\"{Binding SelectedBottomType}\"\n                                          Padding=\"8\"/>\n                            </StackPanel>\n                        </StackPanel>\n                    </GroupBox>\n\n                    <GroupBox Header=\"Результаты расчета\" Padding=\"15\" Margin=\"0,0,0,15\">\n                        <StackPanel>\n                            <StackPanel Orientation=\"Horizontal\" Margin=\"0,0,0,10\">\n                                <TextBlock Text=\"Объем:\" FontWeight=\"Bold\" Width=\"80\"/>\n                                <TextBlock Text=\"{Binding CalculatedVolume, StringFormat='{0:F2}'}\"/>\n                                <TextBlock Text=\"м³\" Margin=\"5,0,0,0\"/>\n                            </StackPanel>\n                            <StackPanel Orientation=\"Horizontal\" Margin=\"0,0,0,10\">\n                                <TextBlock Text=\"Масса:\" FontWeight=\"Bold\" Width=\"80\"/>\n                                <TextBlock Text=\"{Binding CalculatedMass, StringFormat='{0:F2}'}\"/>\n                                <TextBlock Text=\"кг\" Margin=\"5,0,0,0\"/>\n                            </StackPanel>\n                            <StackPanel Orientation=\"Horizontal\" Margin=\"0,0,0,10\">\n                                <TextBlock Text=\"Площадь:\" FontWeight=\"Bold\" Width=\"80\"/>\n                                <TextBlock Text=\"{Binding CalculatedArea, StringFormat='{0:F2}'}\"/>\n                                <TextBlock Text=\"м²\" Margin=\"5,0,0,0\"/>\n                            </StackPanel>\n                        </StackPanel>\n                    </GroupBox>\n\n                    <StackPanel>\n                        <Button Content=\"Сброс\" Command=\"{Binding ResetCommand}\" \n                                Padding=\"10\" Margin=\"0,0,0,10\"\n                                Background=\"#E74C3C\" \n                                Foreground=\"White\" \n                                FontSize=\"14\" \n                                FontWeight=\"Bold\"/>\n                        <Button Content=\"Экспорт результатов\" Command=\"{Binding ExportCommand}\" \n                                Padding=\"10\"\n                                Background=\"#27AE60\" \n                                Foreground=\"White\" \n                                FontSize=\"14\" \n                                FontWeight=\"Bold\"/>\n                    </StackPanel>\n                </StackPanel>\n            </ScrollViewer>\n\n            <Grid Grid.Column=\"1\" Background=\"#E8E8E8\">\n                <h:HelixViewport Background=\"White\">\n                    <h:ModelVisual3D Content=\"{Binding Model3D}\"/>\n                </h:HelixViewport>\n            </Grid>\n        </Grid>\n    </DockPanel>\n</Window>\n