<Window x:Class="ReservoirCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="http://helix-toolkit.org/wpf"
        xmlns:local="clr-namespace:ReservoirCalculator.Converters"
        Title="Калькулятор РВС/РГС - Расчет кубатуры резервуаров" 
        Height="900" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <local:ReservoirTypeConverter x:Key="ReservoirTypeConverter"/>
    </Window.Resources>
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Background="#2C3E50" Padding="20" Orientation="Horizontal">
            <TextBlock Text="Калькулятор резервуаров РВС/РГС" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       VerticalAlignment="Center"/>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Background="White" Padding="20">
                <StackPanel Spacing="15">
                    <GroupBox Header="Тип резервуара" Padding="15">
                        <StackPanel Spacing="10">
                            <ComboBox ItemsSource="{Binding ReservoirTypes}" 
                                      SelectedItem="{Binding SelectedReservoirType}"
                                      Padding="8"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Основные параметры" Padding="15">
                        <StackPanel Spacing="12">
                            <StackPanel>
                                <TextBlock Text="Диаметр (м):" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Diameter, StringFormat=F2}" 
                                         Padding="8" 
                                         FontSize="12"/>
                                <Slider Value="{Binding Diameter}" 
                                        Minimum="1" 
                                        Maximum="20" 
                                        Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Высота/Длина (м):" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Height, StringFormat=F2}" 
                                         Padding="8" 
                                         FontSize="12"/>
                                <Slider Value="{Binding Height}" 
                                        Minimum="1" 
                                        Maximum="25" 
                                        Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Толщина стенок (мм):" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding WallThickness, StringFormat=F1}" 
                                         Padding="8" 
                                         FontSize="12"/>
                                <Slider Value="{Binding WallThickness}" 
                                        Minimum="5" 
                                        Maximum="50" 
                                        Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Параметры РВС" Padding="15" 
                              Visibility="{Binding SelectedReservoirType, Converter={StaticResource ReservoirTypeConverter}, ConverterParameter=РВС}">
                        <StackPanel Spacing="12">
                            <StackPanel>
                                <TextBlock Text="Тип крыши:" FontWeight="Bold" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding RoofTypes}" 
                                          SelectedItem="{Binding SelectedRoofType}"
                                          Padding="8"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Высота крыши (м):" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding RoofHeight, StringFormat=F2}" 
                                         Padding="8" 
                                         FontSize="12"/>
                                <Slider Value="{Binding RoofHeight}" 
                                        Minimum="0.2" 
                                        Maximum="3" 
                                        Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Параметры РГС" Padding="15" 
                              Visibility="{Binding SelectedReservoirType, Converter={StaticResource ReservoirTypeConverter}, ConverterParameter=РГС}">
                        <StackPanel Spacing="12">
                            <StackPanel>
                                <TextBlock Text="Тип днища:" FontWeight="Bold" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding BottomTypes}" 
                                          SelectedItem="{Binding SelectedBottomType}"
                                          Padding="8"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Результаты расчета" Padding="15">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Объем:" FontWeight="Bold" Width="80"/>
                                <TextBlock Text="{Binding CalculatedVolume, StringFormat='{0:F2}'}"/>
                                <TextBlock Text="м³"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Масса:" FontWeight="Bold" Width="80"/>
                                <TextBlock Text="{Binding CalculatedMass, StringFormat='{0:F2}'}"/>
                                <TextBlock Text="кг"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Площадь:" FontWeight="Bold" Width="80"/>
                                <TextBlock Text="{Binding CalculatedArea, StringFormat='{0:F2}'}"/>
                                <TextBlock Text="м²"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <StackPanel Spacing="10">
                        <Button Content="Сброс" Command="{Binding ResetCommand}" 
                                Padding="10" 
                                Background="#E74C3C" 
                                Foreground="White" 
                                FontSize="14" 
                                FontWeight="Bold"/>
                        <Button Content="Экспорт результатов" Command="{Binding ExportCommand}" 
                                Padding="10" 
                                Background="#27AE60" 
                                Foreground="White" 
                                FontSize="14" 
                                FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="1" Background="#E8E8E8">
                <h:HelixViewport Background="White">
                    <h:ModelVisual3D Content="{Binding Model3D}"/>
                </h:HelixViewport>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
